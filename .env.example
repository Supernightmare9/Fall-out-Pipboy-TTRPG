# Vault 215 TTRPG — Environment Configuration
# Copy this file to .env and fill in your values before deploying.

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the HTTP / Socket.IO server listens on.
# Render, Heroku, and Glitch set PORT automatically; leave this line commented
# out when deploying to those platforms.
PORT=3000

# ── Overseer Authentication ─────────────────────────────────────────────────────
# Secret code the GM must type when joining as Overseer.
# Change this to something only you know before going live!
ADMIN_CODE=OVERSEER215

# ── CORS ───────────────────────────────────────────────────────────────────────
# Allowed origin for Socket.IO connections.
# Set to your exact front-end URL in production (e.g. https://vault215.onrender.com).
# Use * only for local/dev testing.
CORS_ORIGIN=*
